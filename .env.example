# PixelCheck Environment Variables
# Copy this file to .env and fill in your values

# ── Design Source Tokens ──────────────────────────────────────

# Figma Personal Access Token
# Get from: figma.com → Account Settings → Personal access tokens
FIGMA_TOKEN=figd_your_token_here

# Zeplin Personal Access Token
# Get from: zeplin.io → Profile → Developer → Personal access tokens
ZEPLIN_TOKEN=zpat_your_token_here

# ── AI Analysis ───────────────────────────────────────────────

# Anthropic API Key (used for Claude AI visual analysis)
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Server (optional) ─────────────────────────────────────────

# API server port (default: 3001)
PORT=3001

# Directory for storing generated reports (default: ./pixelcheck-reports)
REPORTS_DIR=./pixelcheck-reports
